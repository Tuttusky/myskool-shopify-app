{{ 'widget.css' | asset_url | stylesheet_tag }}
<script src="{{ 'widget.js' | asset_url }}" defer></script>

{% comment %}
  Default must hit the Remix app JSON API. Shop URLs like …/apps/myskool/… return HTML (theme) until App Proxy is fully configured — that caused "non-JSON HTTP 200".
{% endcomment %}
{% assign default_upload_url = 'https://myskool-shopify-app-production.up.railway.app/api/upload-photo' %}

<div
  id="myskool-widget-root"
  class="myskool-widget-root"
  data-api-url="{% if block.settings.photo_upload_api_url != blank %}{{ block.settings.photo_upload_api_url }}{% else %}{{ default_upload_url }}{% endif %}"
  data-shop-origin="{{ shop.secure_url }}"
  data-button-label="{{ block.settings.button_label }}"
  data-product-id="{{ product.id }}"
  data-variant-id="{{ product.selected_or_first_available_variant.id }}"
></div>

{% schema %}
{
  "name": "Label widget",
  "target": "section",
  "templates": ["product"],
  "settings": [
    {
      "type": "url",
      "id": "photo_upload_api_url",
      "label": "Photo upload API URL",
      "info": "Leave blank to use the hosted API (JSON). Use your-shop.myshopify.com/apps/myskool/api/upload-photo only after App Proxy is deployed and verified — otherwise the store returns HTML."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Floating button label",
      "default": "Personalise This"
    }
  ]
}
{% endschema %}
