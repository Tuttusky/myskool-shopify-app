{{ 'widget.css' | asset_url | stylesheet_tag }}
<script src="{{ 'widget.js' | asset_url }}" defer></script>

{% comment %}
  App Proxy path: same-origin from the storefront, no CORS.
  Requires `shopify app deploy` so Shopify routes /apps/myskool/* → Railway.
{% endcomment %}
{% assign default_upload_url = '/apps/myskool/api/upload-photo' %}

<div
  id="myskool-widget-root"
  class="myskool-widget-root"
  data-api-url="{% if block.settings.photo_upload_api_url != blank %}{{ block.settings.photo_upload_api_url }}{% else %}{{ default_upload_url }}{% endif %}"
  data-shop-origin="{{ shop.secure_url }}"
  data-button-label="{{ block.settings.button_label }}"
  data-product-id="{{ product.id }}"
  data-variant-id="{{ product.selected_or_first_available_variant.id }}"
  {% if block.settings.product_form_id != blank %}data-product-form-id="{{ block.settings.product_form_id }}"{% endif %}
  data-cart-sections="{{ block.settings.cart_section_ids }}"
></div>

{% schema %}
{
  "name": "Label widget",
  "target": "section",
  "templates": ["product"],
  "settings": [
    {
      "type": "url",
      "id": "photo_upload_api_url",
      "label": "Photo upload API URL",
      "info": "Leave blank to use the App Proxy (/apps/myskool/api/upload-photo). Only override if using a direct external URL."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Floating button label",
      "default": "Personalise This"
    },
    {
      "type": "text",
      "id": "product_form_id",
      "label": "Product form HTML id",
      "info": "Optional. Set to your theme product form element id (e.g. product-form-template--123456789__main) so the added line matches the selected variant."
    },
    {
      "type": "text",
      "id": "cart_section_ids",
      "label": "Cart AJAX section IDs",
      "default": "cart-drawer,cart-icon-bubble",
      "info": "Comma-separated section IDs for cart/add.js (Dawn: cart-drawer,cart-icon-bubble). Clear to skip if your theme does not use Section Rendering API for the cart."
    }
  ]
}
{% endschema %}
